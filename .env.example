DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/escrow_transaction_service"

# Used when creating transactions (server-to-server, not via gateway).
# Defaults in TransactionsService match local api-gateway targets.
USER_SERVICE_URL=http://127.0.0.1:5001
PRODUCT_SERVICE_URL=http://127.0.0.1:5005

# Same value as product-service INTERNAL_API_SECRET (required for product snapshot on transaction room).
# Outside production, if unset, transaction-service falls back to `change-me` to match product-service `.env.example`.
INTERNAL_API_SECRET=

# Wallet settlement when buyer completes a transaction (must match escrow-service INTERNAL_API_SECRET).
ESCROW_SERVICE_URL=http://127.0.0.1:5003

# Optional
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
